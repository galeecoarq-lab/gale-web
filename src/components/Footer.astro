---
import Logo from './ui/Logo.astro';
import { site } from '../data/site';

const year = new Date().getFullYear();
---

<footer class="bg-[var(--color-negro)] text-[var(--color-cultivado)] relative">
  <div class="container-wide pt-24 lg:pt-32 pb-16 grid gap-14 md:gap-10 md:grid-cols-3 items-start">
    {/* Brand */}
    <div class="reveal">
      <Logo tone="dark" height={42} class="mb-6" />
      <p class="text-sm leading-relaxed text-[var(--color-niebla)] max-w-sm">
        {site.description}
      </p>
    </div>

    {/* Contact */}
    <div class="reveal md:px-4 lg:px-8" data-delay="100">
      <h3 class="text-xs font-semibold tracking-[0.22em] uppercase text-[var(--color-cultivado)] mb-6">
        Contacto
      </h3>
      <ul class="space-y-4 text-sm text-[var(--color-niebla)]">
        <li class="flex items-start gap-3">
          <svg class="mt-0.5 size-4 flex-none text-[var(--color-cultivado)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
            <path d="M12 21s-7-6.2-7-12a7 7 0 1 1 14 0c0 5.8-7 12-7 12Z" />
            <circle cx="12" cy="9" r="2.5" />
          </svg>
          <span>{site.address}</span>
        </li>
        <li class="flex items-start gap-3">
          <svg class="mt-0.5 size-4 flex-none text-[var(--color-cultivado)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
            <rect x="3" y="5" width="18" height="14" rx="2" />
            <path d="m3.5 6.5 8.5 7 8.5-7" />
          </svg>
          <a href={`mailto:${site.email}`} class="hover:text-[var(--color-cultivado)] transition-colors duration-200">
            {site.email}
          </a>
        </li>
        <li class="flex items-start gap-3">
          <svg class="mt-0.5 size-4 flex-none text-[var(--color-cultivado)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
            <path d="M22 16.9v3a2 2 0 0 1-2.2 2 19.8 19.8 0 0 1-8.6-3.1 19.5 19.5 0 0 1-6-6 19.8 19.8 0 0 1-3.1-8.7A2 2 0 0 1 4.1 2h3a2 2 0 0 1 2 1.7c.1.9.3 1.8.6 2.6a2 2 0 0 1-.5 2.1L8 9.6a16 16 0 0 0 6 6l1.2-1.2a2 2 0 0 1 2.1-.5c.8.3 1.7.5 2.6.6a2 2 0 0 1 1.7 2Z" />
          </svg>
          <a href={`tel:${site.phone.replace(/\s/g, '')}`} class="hover:text-[var(--color-cultivado)] transition-colors duration-200">
            {site.phone}
          </a>
        </li>
      </ul>
    </div>

    {/* Socials */}
    <div class="reveal md:justify-self-end md:text-right" data-delay="200">
      <h3 class="text-xs font-semibold tracking-[0.22em] uppercase text-[var(--color-cultivado)] mb-6">
        Síguenos
      </h3>
      <ul class="flex items-center gap-3 md:justify-end">
        <li>
          <a
            href={site.social.instagram}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Instagram"
            class="inline-flex size-10 items-center justify-center rounded-full border border-[color-mix(in_oklab,var(--color-cultivado)_25%,transparent)] text-[var(--color-cultivado)] hover:bg-[var(--color-cultivado)] hover:text-[var(--color-negro)] transition-colors duration-200"
          >
            <svg class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
              <rect x="3" y="3" width="18" height="18" rx="5" />
              <circle cx="12" cy="12" r="4" />
              <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none" />
            </svg>
          </a>
        </li>
        <li>
          <a
            href={site.social.tiktok}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="TikTok"
            class="inline-flex size-10 items-center justify-center rounded-full border border-[color-mix(in_oklab,var(--color-cultivado)_25%,transparent)] text-[var(--color-cultivado)] hover:bg-[var(--color-cultivado)] hover:text-[var(--color-negro)] transition-colors duration-200"
          >
            <svg class="size-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M16.5 3a5.5 5.5 0 0 0 4.5 4.5v3.1a8.5 8.5 0 0 1-4.5-1.34v6.34a6 6 0 1 1-6-6c.34 0 .67.03 1 .09v3.2a2.9 2.9 0 1 0 2 2.7V3h3Z" />
            </svg>
          </a>
        </li>
        <li>
          <a
            href={site.social.linkedin}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="LinkedIn"
            class="inline-flex size-10 items-center justify-center rounded-full border border-[color-mix(in_oklab,var(--color-cultivado)_25%,transparent)] text-[var(--color-cultivado)] hover:bg-[var(--color-cultivado)] hover:text-[var(--color-negro)] transition-colors duration-200"
          >
            <svg class="size-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M4.98 3.5A2.5 2.5 0 1 1 5 8.5a2.5 2.5 0 0 1-.02-5ZM3 9.75h4V21H3V9.75ZM9.5 9.75h3.83v1.54h.05a4.2 4.2 0 0 1 3.78-2.08c4.05 0 4.79 2.67 4.79 6.14V21h-4v-4.86c0-1.16-.02-2.65-1.62-2.65-1.62 0-1.87 1.27-1.87 2.57V21h-4V9.75Z" />
            </svg>
          </a>
        </li>
      </ul>
    </div>
  </div>

  <hr class="hr-hair text-[var(--color-cultivado)] container-wide" />

  <div class="container-wide py-8 flex flex-col md:flex-row items-start md:items-center justify-between gap-3">
    <p class="text-xs text-[var(--color-niebla)] tracking-wide">
      © {year} {site.longName}. Todos los derechos reservados.
    </p>
    <p class="text-xs text-[var(--color-niebla)] tracking-wide">
      Construido por
      <a
        href="https://softblocks.lat"
        target="_blank"
        rel="noopener noreferrer"
        class="text-[var(--color-cultivado)] hover:text-[var(--color-azul-soft)] transition-colors duration-200"
      >
        BloqueStudio
      </a>
    </p>
  </div>
</footer>
