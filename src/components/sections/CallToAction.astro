---
/**
 * Closing CTA / "Contacto" — full-bleed dark panel with the closing line and
 * the three contact actions the client asked for: Correo, Instagram, Agendar
 * reunión.
 */
import Eyebrow from '../ui/Eyebrow.astro';
import Reveal from '../ui/Reveal.astro';
import { links } from '../../data/site';

interface Props {
  eyebrow?: string;
  title?: string;
  description?: string;
  image?: string;
}

const {
  eyebrow = 'Conversemos',
  title = 'Cada proyecto empieza por una buena conversación.',
  description = 'Transformemos tu idea en un espacio funcional, rentable y memorable.',
  image = '/images/projects/casita-del-pan.webp',
} = Astro.props;

const solid =
  'inline-flex items-center gap-2.5 rounded-full bg-[var(--color-cultivado)] px-6 py-3.5 text-sm font-medium tracking-wide text-[var(--color-negro)] transition-colors duration-300 hover:bg-[var(--color-azul)] hover:text-[var(--color-cultivado)]';
const outline =
  'inline-flex items-center gap-2.5 rounded-full border border-[color-mix(in_oklab,var(--color-cultivado)_40%,transparent)] px-6 py-3.5 text-sm font-medium tracking-wide text-[var(--color-cultivado)] transition-colors duration-300 hover:border-[var(--color-cultivado)] hover:bg-[var(--color-cultivado)] hover:text-[var(--color-negro)]';
---

<section id="contacto" class="section bg-[var(--color-negro)] text-[var(--color-cultivado)] relative overflow-hidden">
  <div class="absolute inset-0 opacity-25" aria-hidden="true">
    <img src={image} alt="" class="h-full w-full object-cover" loading="lazy" decoding="async" />
    <div class="absolute inset-0 bg-gradient-to-r from-[var(--color-negro)]/95 via-[var(--color-negro)]/80 to-[var(--color-negro)]/40"></div>
  </div>

  <div class="pointer-events-none absolute inset-y-0 right-0 z-10 hidden lg:flex items-end justify-end pr-8 xl:pr-16" aria-hidden="true">
    <Reveal delay={200}>
      <img
        src="/images/sprites/sprit-04.png"
        alt=""
        class="w-72 xl:w-[26rem] h-auto opacity-90 -scale-x-100"
        loading="lazy"
        decoding="async"
      />
    </Reveal>
  </div>

  <div class="container-wide relative">
    <div class="max-w-3xl">
      <Reveal><Eyebrow class="text-[var(--color-niebla)]">{eyebrow}</Eyebrow></Reveal>
      <Reveal delay={100} as="h2" class="display-2xl mt-6 text-balance">
        {title}
      </Reveal>
      <Reveal delay={200} as="p" class="mt-8 max-w-xl text-base sm:text-lg leading-relaxed text-[var(--color-niebla)]">
        {description}
      </Reveal>
      <Reveal delay={300} class="mt-10 flex flex-wrap items-center gap-3">
        <a href={links.correo} class={outline}>
          <svg class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
            <rect x="3" y="5" width="18" height="14" rx="2" />
            <path d="m3.5 6.5 8.5 7 8.5-7" />
          </svg>
          Correo
        </a>
        <a href={links.instagram} target="_blank" rel="noopener noreferrer" class={outline}>
          <svg class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
            <rect x="3" y="3" width="18" height="18" rx="5" />
            <circle cx="12" cy="12" r="4" />
            <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none" />
          </svg>
          Instagram
        </a>
        <a href={links.reunion} target="_blank" rel="noopener noreferrer" class={solid}>
          <svg class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
            <rect x="3" y="4.5" width="18" height="16" rx="2" />
            <path d="M3 9h18M8 3v3m8-3v3" />
          </svg>
          Agendar reunión
        </a>
      </Reveal>
    </div>
  </div>
</section>
