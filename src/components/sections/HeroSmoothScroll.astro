---
/**
 * Smooth-scroll hero — the image starts full-bleed and contracts into a
 * centered window as the user scrolls. Copy (title, subtitle, CTAs and the
 * quick-indicators strip) sits on top and fades away on scroll.
 *
 * `useScroll` needs the browser, so the React island hydrates with client:load.
 */
import SmoothScrollHero from '../ui/smooth-scroll-hero.tsx';
import { hero, heroStats, presence } from '../../data/site';

interface Props {
  scrollHeight?: number;
  desktopImage?: string;
  mobileImage?: string;
  initialClipPercentage?: number;
  finalClipPercentage?: number;
  /** Set true to render the title in azul cerúleo (client A/B request). */
  titleInAzul?: boolean;
}

const {
  scrollHeight = 640,
  desktopImage = '/images/hero/hero-desktop.webp',
  mobileImage = '/images/hero/hero-mobile.webp',
  initialClipPercentage = 25,
  finalClipPercentage = 75,
  titleInAzul = false,
} = Astro.props;
---

<SmoothScrollHero
  client:load
  scrollHeight={scrollHeight}
  desktopImage={desktopImage}
  mobileImage={mobileImage}
  initialClipPercentage={initialClipPercentage}
  finalClipPercentage={finalClipPercentage}
  title={hero.title}
  subtitle={hero.subtitle}
  ctas={hero.ctas}
  stats={heroStats}
  presenceLabel={presence.label}
  presenceCities={presence.cities}
  presenceSuffix={presence.suffix}
  titleInAzul={titleInAzul}
/>
