---
/**
 * Smooth-scroll hero — reversed direction.
 * Image starts full-bleed and contracts into a centered window as the user scrolls.
 *
 * The framer-motion component is mounted as a React island; `useScroll` needs
 * the browser, so we pass `client:load` to hydrate immediately.
 */
import SmoothScrollHero from '../ui/smooth-scroll-hero.tsx';
import { heroStatement } from '../../data/site';

interface Props {
  scrollHeight?: number;
  desktopImage?: string;
  mobileImage?: string;
  initialClipPercentage?: number;
  finalClipPercentage?: number;
  statementLine1?: string;
  statementLine2?: string;
}

const {
  scrollHeight = 1500,
  desktopImage = '/images/hero/hero-interior-07.webp',
  mobileImage = '/images/hero/hero-mobile.webp',
  initialClipPercentage = 25,
  finalClipPercentage = 75,
  statementLine1 = heroStatement.line1,
  statementLine2 = heroStatement.line2,
} = Astro.props;
---

<SmoothScrollHero
  client:load
  scrollHeight={scrollHeight}
  desktopImage={desktopImage}
  mobileImage={mobileImage}
  initialClipPercentage={initialClipPercentage}
  finalClipPercentage={finalClipPercentage}
  statementLine1={statementLine1}
  statementLine2={statementLine2}
/>
