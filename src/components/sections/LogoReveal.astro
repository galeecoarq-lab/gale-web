---
/**
 * Brand logo expansion — the GALE mark assembles at screen centre,
 * then on scroll the two corner brackets separate outward to their
 * respective screen corners while the inner letters fade out. Once
 * settled, the brackets persist as fixed corner accents over every
 * section below.
 *
 * Implementation: the bracket layer is moved to <body> on mount so the
 * position:fixed pieces can't be trapped by any ancestor containing
 * block (motion.div transforms in neighbouring sections would otherwise
 * clip them). The <section> element only acts as a 160vh scroll-driver
 * — its rect.top feeds `--p` (translate progress) and `--enter`
 * (fade-in), which are set on <html> so the moved layer inherits them.
 */
---

<section class="logo-reveal-section" data-logo-reveal aria-hidden="true"></section>

<div class="logo-reveal-layer" data-logo-reveal-layer aria-hidden="true">
  <svg
    class="logo-reveal-piece logo-reveal-bracket-bl"
    viewBox="0 0 1200 1002"
    preserveAspectRatio="xMidYMid meet"
    xmlns="http://www.w3.org/2000/svg"
  >
    <path fill="var(--color-azul)" d="M0 0L106.467 0L106.536 910.093L474.087 910.136L599.603 910.133C622.031 910.131 645.232 910.431 667.615 910.036C667.677 940.07 667.023 972.16 667.702 1002L0 1002L0 0Z" />
  </svg>
  <svg
    class="logo-reveal-piece logo-reveal-bracket-tr"
    viewBox="0 0 1200 1002"
    preserveAspectRatio="xMidYMid meet"
    xmlns="http://www.w3.org/2000/svg"
  >
    <path fill="var(--color-azul)" d="M532.11 0L1200 0L1200 395.114C1190.88 395.935 1172.64 395.4 1162.97 395.397L1093.23 395.322L1093.25 91.9309C1069.88 91.552 1045.38 91.8826 1021.94 91.8797L884.382 91.8732L532.119 91.9346C531.619 61.7348 532.089 30.2677 532.11 0Z" />
  </svg>
  <svg
    class="logo-reveal-piece logo-reveal-letters"
    viewBox="0 0 1200 1002"
    preserveAspectRatio="xMidYMid meet"
    xmlns="http://www.w3.org/2000/svg"
  >
    <path fill="var(--color-azul)" d="M620.193 572.188L659.609 572.068C692.162 643.657 724.025 716.355 757.14 787.616C743.051 787.675 728.961 787.658 714.872 787.564C707.625 771.24 700.513 754.203 693.534 737.747L659.473 737.709L585.908 737.733C578.862 754.424 571.725 771.076 564.496 787.688L523.105 787.536L582.672 655.307C594.891 628.117 607.382 598.971 620.193 572.188ZM599.39 706.579C612.522 706.016 627.863 706.38 641.162 706.402C653.601 706.409 667.738 706.104 680.039 706.563L650.056 636.88C648.704 633.727 640.56 614.199 639.434 612.716L599.39 706.579Z" />
    <path fill="var(--color-azul)" d="M365.966 566.282C398.329 563.773 434.032 572.728 457.253 596.062C459.052 597.869 460.474 599.33 461.9 601.442L436.576 626.178C410.324 599.389 368.969 593.331 336.105 611.369C319.632 620.411 307.477 635.686 302.364 653.769C296.792 673.079 298.472 697.036 308.481 714.683C318.1 731.782 334.212 744.275 353.167 749.332C375.23 755.402 401.287 752.431 421.233 741.093C420.841 725.299 421.058 708.893 421.076 693.05L421.21 686.889L459.442 686.82L459.355 760.076C441.145 776.47 410.17 785.123 386.147 787.271C322.284 792.981 262.868 752.536 258.642 684.787C254.544 619.09 301.104 570.617 365.966 566.282Z" />
    <path fill="var(--color-azul)" d="M820.885 572.153C834.313 572.253 847.743 572.187 861.169 571.956C861.917 588.929 861.291 610.997 861.288 628.292L861.336 753.621C898.463 753.077 936.781 753.53 974.02 753.526C973.838 760.149 974.54 783.435 973.78 787.743C923.79 786.749 870.83 787.628 820.607 787.631L820.674 642.415L820.601 597.214C820.585 590.636 820.251 578.292 820.885 572.153Z" />
    <path fill="var(--color-azul)" d="M1037.71 572.2C1089.96 571.371 1143.04 572.882 1195.36 571.978C1195.54 583.169 1195.37 594.876 1195.36 606.106C1181.79 605.546 1166.14 605.92 1152.44 605.927L1078.02 605.887C1077.8 624.323 1078.06 643.272 1077.98 661.782C1111.54 660.589 1147.88 662.467 1181.98 661.529C1181.84 672.711 1181.83 683.895 1181.93 695.078C1147.97 694.394 1112.13 694.966 1078.02 694.958L1078.13 754.06C1105.95 752.967 1134.87 754.374 1162.81 753.861C1174.61 753.645 1188.32 753.377 1200 754.075L1200 787.416C1195.35 787.958 1186.29 787.679 1181.22 787.666L1148.22 787.603L1037.66 787.586C1037.27 760.443 1037.63 732.383 1037.62 705.179L1037.71 572.2Z" />
  </svg>
</div>

<style is:global>
  :root {
    --logo-p: 0;
    --logo-enter: 0;
    --logo-nav-h: 64px;
    --logo-w: clamp(220px, 26vw, 360px);
    --logo-h: calc(var(--logo-w) * 1002 / 1200);
    --logo-gap-x: calc(50vw - var(--logo-w) / 2);
    --logo-gap-y: calc(50vh - var(--logo-h) / 2 - var(--logo-nav-h) / 2);
  }

  @media (min-width: 768px) {
    :root { --logo-nav-h: 80px; }
  }

  .logo-reveal-section {
    position: relative;
    height: 160vh;
    background: var(--color-cultivado);
  }

  .logo-reveal-layer {
    position: fixed;
    inset: 0;
    pointer-events: none;
    /* High z-index so the corner brackets always sit above subsequent
       sections (parallax images, sticky panels, etc.) — but below the
       navbar (z-50). */
    z-index: 45;
  }

  .logo-reveal-piece {
    position: absolute;
    top: calc(50% + var(--logo-nav-h) / 2);
    left: 50%;
    width: var(--logo-w);
    height: var(--logo-h);
    display: block;
    will-change: transform, opacity;
  }

  .logo-reveal-letters {
    transform: translate3d(-50%, -50%, 0);
    opacity: calc(var(--logo-enter) * (1 - clamp(0, var(--logo-p) * 3, 1)));
  }

  .logo-reveal-bracket-bl {
    opacity: var(--logo-enter);
    transform: translate3d(
      calc(-50% - var(--logo-gap-x) * var(--logo-p)),
      calc(-50% + var(--logo-gap-y) * var(--logo-p)),
      0
    );
  }

  .logo-reveal-bracket-tr {
    opacity: var(--logo-enter);
    transform: translate3d(
      calc(-50% + var(--logo-gap-x) * var(--logo-p)),
      calc(-50% - var(--logo-gap-y) * var(--logo-p)),
      0
    );
  }

  @media (prefers-reduced-motion: reduce) {
    .logo-reveal-section { height: 100vh; }
  }
</style>

<script>
  const section = document.querySelector<HTMLElement>('[data-logo-reveal]');
  const layer = document.querySelector<HTMLElement>('[data-logo-reveal-layer]');

  if (section && layer) {
    // Reparent the fixed layer to <body> so no ancestor containing block
    // (motion.div transforms in neighbouring sections, etc.) can trap it.
    document.body.appendChild(layer);

    let rafId: number | null = null;
    const root = document.documentElement;

    const update = () => {
      const rect = section.getBoundingClientRect();
      const sectionH = section.offsetHeight;
      const viewportH = window.innerHeight;
      const scrollable = Math.max(0, sectionH - viewportH);

      // Has the user scrolled all the way past the section's pin range?
      // Once true, the brackets are locked at their corner positions.
      const passed = rect.top <= -scrollable;

      let progress: number;
      let enter: number;

      if (passed) {
        progress = 1;
        enter = 1;
      } else if (rect.top <= 0) {
        // Inside the section's scroll-driver range.
        progress = scrollable > 0 ? Math.min(-rect.top / scrollable, 1) : 0;
        enter = 1;
      } else {
        // Section still below the viewport — fade in as it approaches.
        progress = 0;
        const fadeRange = 140;
        enter =
          rect.top >= fadeRange ? 0 : (fadeRange - rect.top) / fadeRange;
      }

      root.style.setProperty('--logo-p', String(progress));
      root.style.setProperty('--logo-enter', String(enter));
    };

    const onScroll = () => {
      if (rafId !== null) return;
      rafId = requestAnimationFrame(() => {
        update();
        rafId = null;
      });
    };

    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', onScroll);
    // Re-measure once images/fonts load, since later layout shifts can
    // change the section's offsetTop and leave the variables stale.
    window.addEventListener('load', update);
    update();
  }
</script>
