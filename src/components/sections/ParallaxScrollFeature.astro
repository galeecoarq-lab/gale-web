---
/**
 * Parallax scroll feature — full-bleed scroll-driven reveal of each
 * step in the "Cómo trabajamos" process, with alternating layout.
 * Wraps the React component so the data lives alongside the rest of
 * the site copy.
 */
import { process } from '../../data/site';
import ParallaxScrollFeatureSection from '../ui/parallax-scroll-feature-section.tsx';

const sections = process.map((step, idx) => ({
  id: step.step,
  title: step.title,
  description: step.description,
  imageUrl: step.image,
  spriteUrl: step.spriteImage,
  spriteVideoUrl: step.spriteVideo,
  reverse: idx % 2 === 1,
}));
---

<ParallaxScrollFeatureSection
  client:visible
  eyebrow="Cómo trabajamos"
  headline="Un proceso claro y a la medida."
  intro="Desde la primera conversación hasta la entrega, te acompañamos paso a paso. Diseñamos con rigor y construimos con detalle, asegurando que el resultado cumpla y emocione."
  sections={sections}
/>
