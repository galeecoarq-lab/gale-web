---
/**
 * "Lo que hacemos" — visual gallery of recent work.
 * A six-image strip where each tile expands on hover, replacing the
 * previous numbered services list.
 */
import ImageGallery from '../ui/image-gallery.tsx';

const items = [
  { src: '/images/projects/casita-del-pan-jaen/foto-02.webp', alt: 'Casita del Pan — Jaén', caption: 'Casita del Pan, Jaén' },
  { src: '/images/projects/corporativo-lcs-jaen/foto-05.webp', alt: 'Corporativo LCS — Jaén', caption: 'LCS, Jaén' },
  { src: '/images/projects/maguis-chicken-pucallpa/foto-01.webp', alt: 'Maguis Chicken — Pucallpa', caption: 'Maguis Chicken, Pucallpa' },
  { src: '/images/projects/residencial-casa-jaen/foto-03.webp', alt: 'Residencial Casa — Jaén', caption: 'Casa, Jaén' },
  { src: '/images/projects/salud-coa-jaen/foto-04.webp', alt: 'Salud COA — Jaén', caption: 'COA, Jaén' },
  { src: '/images/projects/turistico-lacolpa-sanignacio/foto-06.webp', alt: 'Turístico La Colpa — San Ignacio', caption: 'La Colpa, San Ignacio' },
];
---

<section id="servicios" class="section bg-[var(--color-negro)] text-[var(--color-cultivado)]">
  <ImageGallery
    client:visible
    eyebrow="Lo que hacemos"
    title="Nuestras creaciones más recientes."
    description="Una colección visual de nuestros trabajos — cada espacio diseñado con intención, materialidad honesta y sensibilidad por el lugar."
    items={items}
  />
</section>
