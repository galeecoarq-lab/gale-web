---
import ArrowIcon from './ArrowIcon.astro';

interface Props {
  href?: string;
  variant?: 'primary' | 'secondary' | 'ghost' | 'link';
  icon?: boolean;
  class?: string;
  type?: 'button' | 'submit' | 'reset';
  ariaLabel?: string;
}

const {
  href,
  variant = 'primary',
  icon = true,
  class: className = '',
  type = 'button',
  ariaLabel,
} = Astro.props;

const classes = `btn btn-${variant} ${className}`;
const Tag = href ? 'a' : 'button';
---

<Tag
  class={classes}
  href={href}
  type={!href ? type : undefined}
  aria-label={ariaLabel}
>
  <span><slot /></span>
  {icon && <ArrowIcon class="w-4 h-4" />}
</Tag>
