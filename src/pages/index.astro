---
import BaseLayout         from '../layouts/BaseLayout.astro';
import HeroSmoothScroll   from '../components/sections/HeroSmoothScroll.astro';
import ImageMosaic        from '../components/sections/ImageMosaic.astro';
import ClientsOpinions    from '../components/sections/ClientsOpinions.astro';
import Services           from '../components/sections/Services.astro';
import SectorsCarousel    from '../components/sections/SectorsCarousel.astro';
import ParallaxScrollFeature from '../components/sections/ParallaxScrollFeature.astro';
import LogoReveal         from '../components/sections/LogoReveal.astro';
import Process            from '../components/sections/Process.astro';
import ValuesMarquee      from '../components/sections/ValuesMarquee.astro';
import CallToAction       from '../components/sections/CallToAction.astro';
---

<BaseLayout
  title="GALE — Arquitectura sustentable | Diseñamos espacios y mejores experiencias"
  description="Estudio de arquitectura en Lima especializado en diseño residencial, comercial, turístico y corporativo con un enfoque sustentable."
  navTheme="dark"
>
  <HeroSmoothScroll />

  <SectorsCarousel />

  <ParallaxScrollFeature />

  <!-- <LogoReveal /> -->

  <ImageMosaic />

  <ClientsOpinions />

  <Services />

  <Process />

  <ValuesMarquee />

  <CallToAction />
</BaseLayout>
